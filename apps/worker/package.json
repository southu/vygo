{
  "name": "@vygo/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/lib.ts",
      "default": "./src/lib.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test test/**/*.test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@vygo/config": "workspace:*",
    "@vygo/db": "workspace:*",
    "@vygo/email": "workspace:*",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
