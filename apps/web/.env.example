# apps/web — public / browser-safe values only. Never put secrets here.
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
# Public HTTPS origin of the Railway-hosted API the frontend targets.
# Production (Vercel) uses the Railway API custom domain; unset falls back to it.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# Production example:
# NEXT_PUBLIC_API_BASE_URL=https://api.vygo.ai
# Cloudflare Turnstile site key (public)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Optional local override; production uses VERCEL_GIT_COMMIT_SHA
COMMIT_SHA=
