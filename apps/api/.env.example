# apps/api — server-side only. Do not commit real credentials.
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://vygo:vygo@localhost:5432/vygo
REDIS_URL=redis://localhost:6379
# Resend (leave blank locally if not sending mail)
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
# Cloudflare Turnstile secret (server-side validation)
TURNSTILE_SECRET_KEY=
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=info
