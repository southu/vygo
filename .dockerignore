# Keep the Docker build context small and reproducible: install deps inside the
# image from the committed lockfile, never copy host artifacts.
node_modules
**/node_modules
.git
.github

# Build / tooling output
dist
**/dist
.next
**/.next
apps/web/out
coverage
**/coverage
*.tsbuildinfo

# Local env / secrets (never ship into an image)
.env
.env.*
!.env.example
!**/.env.example

# Private planning material
external-docs

# OS / editor
.DS_Store
.idea
.vscode
*.swp

# Test/report artifacts
apps/web/test-results
apps/web/playwright-report
.vercel
