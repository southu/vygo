# Root workspace — copy to .env for local tooling. No real secrets.
# Variable NAMES and safe placeholders only. Fill real values in Railway/Vercel
# or from the owner's secret vault — never commit credential values.
NODE_ENV=development

# Port the API binds to (0.0.0.0:$PORT). Railway injects PORT in production.
PORT=4000

# Shared local database / cache (used by api + worker)
DATABASE_URL=postgresql://vygo:vygo@localhost:5432/vygo
DATABASE_URL_TEST=postgresql://vygo:vygo@localhost:5432/vygo_test
REDIS_URL=redis://localhost:6379

# Allowed browser origins for the API (comma-separated). Include the Vercel
# marketing origin(s) that call the API in production. ALLOWED_ORIGINS is an
# accepted alias. Both the Railway API and the edge health surfaces default-allow
# https://www.vygo.ai and https://vygo.ai, plus vygo Vercel preview origins
# matching ^https://vygo(-[a-z0-9-]+)?\.vercel\.app$ (reflected individually,
# never a `*` wildcard). Extend here for extra staging origins.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://127.0.0.1:8380
# Production example (allowed Vercel origin):
# CORS_ORIGINS=https://www.vygo.ai,https://vygo.ai
# ALLOWED_ORIGINS=https://www.vygo.ai

# Public API base URL the marketing frontend targets (browser-exposed, non-secret).
# Production (Vercel) targets the Railway API: https://api.vygo.ai
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare Turnstile — official always-pass test secret for local/CI (server-side)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# Cloudflare Turnstile site key (public, browser-exposed)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Versioned IP hash salts (never log raw IPs)
IP_HASH_SALT=local-dev-ip-hash-salt-change-me
IP_HASH_SALT_VERSION=1
# IP_HASH_SALT_PREVIOUS=
# IP_HASH_SALT_PREVIOUS_VERSION=1

# Rate limits
RATE_LIMIT_IP_MAX=20
RATE_LIMIT_IP_WINDOW_SECONDS=3600
RATE_LIMIT_EMAIL_MAX=5
RATE_LIMIT_EMAIL_WINDOW_SECONDS=3600
MIN_FORM_COMPLETION_MS=2000

# Non-production inspection + integration-report routes
ENABLE_TEST_SURFACE=true
# TEST_FAULT_MODE=none

# Internal ops Basic Auth (readiness list / brief / CSV). Fail closed when password unset.
# Never commit real values. Production: set on Railway service `api` only.
OPS_BASIC_AUTH_USER=ops
# OPS_BASIC_AUTH_PASSWORD=


# Deployed git SHA (drives GET /version and the health surfaces' commit field).
# Production reads VERCEL_GIT_COMMIT_SHA (Vercel) / GIT_COMMIT_SHA / GITHUB_SHA;
# COMMIT_SHA is an optional local override for /version testing.
COMMIT_SHA=

# Email / Resend (worker + webhooks)
RESEND_API_KEY=
# Svix-style secret: whsec_<base64>
RESEND_WEBHOOK_SECRET=
EMAIL_FROM=Vygo <hello@vygo.ai>
LEAD_NOTIFICATION_EMAIL=hello@vygo.ai
# Local live harness runs the worker in-process with the API
INLINE_EMAIL_WORKER=true
WORKER_POLL_INTERVAL_MS=2000
WORKER_MAX_ATTEMPTS=5
