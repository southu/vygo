# Root workspace — copy to .env for local tooling. No real secrets.
NODE_ENV=development

# Shared local database / cache (used by api + worker)
DATABASE_URL=postgresql://vygo:vygo@localhost:5432/vygo
DATABASE_URL_TEST=postgresql://vygo:vygo@localhost:5432/vygo_test
REDIS_URL=redis://localhost:6379

# API CORS allowlist (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://127.0.0.1:8380

# Cloudflare Turnstile — official always-pass test secret for local/CI
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Versioned IP hash salts (never log raw IPs)
IP_HASH_SALT=local-dev-ip-hash-salt-change-me
IP_HASH_SALT_VERSION=1
# IP_HASH_SALT_PREVIOUS=
# IP_HASH_SALT_PREVIOUS_VERSION=1

# Rate limits
RATE_LIMIT_IP_MAX=20
RATE_LIMIT_IP_WINDOW_SECONDS=3600
RATE_LIMIT_EMAIL_MAX=5
RATE_LIMIT_EMAIL_WINDOW_SECONDS=3600
MIN_FORM_COMPLETION_MS=2000

# Non-production inspection + integration-report routes
ENABLE_TEST_SURFACE=true
# TEST_FAULT_MODE=none

# Optional: bake a SHA for local /version testing
COMMIT_SHA=

# Email / Resend (worker + webhooks)
RESEND_API_KEY=
# Svix-style secret: whsec_<base64>
RESEND_WEBHOOK_SECRET=
EMAIL_FROM=Vygo <hello@vygo.ai>
LEAD_NOTIFICATION_EMAIL=hello@vygo.ai
# Local live harness runs the worker in-process with the API
INLINE_EMAIL_WORKER=true
WORKER_POLL_INTERVAL_MS=2000
WORKER_MAX_ATTEMPTS=5
