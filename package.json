{
  "name": "vygo",
  "private": true,
  "version": "0.0.0",
  "description": "vygo.ai production monorepo — marketing web, API, worker, and shared packages",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "pnpm --filter @vygo/web dev",
    "dev:web": "pnpm --filter @vygo/web dev",
    "dev:api": "pnpm --filter @vygo/api dev",
    "dev:worker": "pnpm --filter @vygo/worker dev",
    "build": "pnpm -r --if-present run build",
    "build:web": "pnpm --filter @vygo/web build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --if-present run typecheck",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck",
    "readiness": "tsx scripts/generate-readiness.ts",
    "foundation-status": "tsx scripts/generate-foundation-status.ts",
    "secret-scan": "tsx scripts/secret-scan.ts",
    "seed:local": "tsx scripts/seed-local.ts",
    "availability:set": "tsx scripts/set-availability.ts",
    "db:migrate": "tsx packages/db/src/cli-migrate.ts",
    "test": "pnpm --filter @vygo/email test && pnpm --filter @vygo/api test",
    "test:integration": "pnpm --filter @vygo/api test",
    "test:email": "pnpm --filter @vygo/email test",
    "test:e2e": "pnpm --filter @vygo/web test:e2e",
    "ci:verify": "pnpm secret-scan && pnpm lint && pnpm format:check && pnpm typecheck && pnpm test:email && pnpm foundation-status && pnpm readiness && pnpm build",
    "clean": "pnpm -r --if-present run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0"
  }
}
