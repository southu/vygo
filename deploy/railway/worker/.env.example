# Railway worker service (apps/worker) — env NAME reference for project `vygo`.
# Separate service from the API, sharing the same DATABASE_URL.
# Fill VALUES in Railway / from the owner's secret vault — never commit values.
# See docs/railway-backend-readiness.md for what each name is for.

NODE_ENV=production
# Railway injects PORT; the worker's HTTP liveness/status server binds 0.0.0.0:$PORT.
PORT=

# Same Railway Postgres as the API. In Railway, wire as a reference (no raw value):
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=
# Optional; only if the worker needs Redis. In Railway, wire as a reference:
#   REDIS_URL=${{Redis.REDIS_URL}}
REDIS_URL=

# Resend (secret vault). Names only here — do not commit values.
RESEND_API_KEY=

# Email identity (not secrets).
EMAIL_FROM=
LEAD_NOTIFICATION_EMAIL=

# Worker tuning (not secrets; defaults live in packages/config).
LOG_LEVEL=info
WORKER_POLL_INTERVAL_MS=
WORKER_BATCH_SIZE=
WORKER_MAX_ATTEMPTS=

# Leave unset/false: this IS the dedicated worker, not the API's inline worker.
INLINE_EMAIL_WORKER=false
