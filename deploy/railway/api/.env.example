# Railway API service (apps/api) — env NAME reference for project `vygo`.
# Copy names into the Railway service's Variables tab. Fill VALUES in Railway
# (or from the owner's secret vault) — never commit real values here.
# See docs/railway-backend-readiness.md for what each name is for.

NODE_ENV=production
# Railway usually injects PORT; the app binds to it (schema default 4000).
PORT=

# From Railway Postgres plugin. In Railway, wire as a reference (no raw value):
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=
# From Railway Redis plugin. In Railway, wire as a reference (no raw value):
#   REDIS_URL=${{Redis.REDIS_URL}}
REDIS_URL=

# Comma-separated allowlist; include the Vercel web origin(s). Not a secret.
# Production: https://www.vygo.ai,https://vygo.ai (vygo Vercel preview origins
# matching https://vygo-*.vercel.app are allowed automatically — see docs/api.md).
CORS_ORIGINS=

# Resend (secret vault). Names only here — do not commit values.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# Cloudflare Turnstile server secret (secret vault). Do not commit value.
TURNSTILE_SECRET_KEY=

# Versioned IP hash salts (secret vault; never log raw IPs). Do not commit values.
IP_HASH_SALT=
IP_HASH_SALT_VERSION=1
# IP_HASH_SALT_PREVIOUS=
# IP_HASH_SALT_PREVIOUS_VERSION=1

# Email identity (not secrets).
EMAIL_FROM=
LEAD_NOTIFICATION_EMAIL=

# Rate limits / tuning (not secrets; defaults live in packages/config).
RATE_LIMIT_IP_MAX=
RATE_LIMIT_IP_WINDOW_SECONDS=
RATE_LIMIT_EMAIL_MAX=
RATE_LIMIT_EMAIL_WINDOW_SECONDS=
MIN_FORM_COMPLETION_MS=
LOG_LEVEL=info

# Production posture: run the worker as a SEPARATE service, lock down test surface.
INLINE_EMAIL_WORKER=false
ENABLE_TEST_SURFACE=false
